# Example environment variables for local development
# Copy this file to .env and fill in your real credentials before running.

DB_HOST=your-db-host.example.com
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=5432

# AWS credentials are usually supplied via AWS CLI or environment variables.
# Uncomment if you want to set them explicitly in .env.
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=your_optional_session_token
# AWS_REGION=ap-south-1
